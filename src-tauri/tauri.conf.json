{
  "$schema": "https://raw.githubusercontent.com/nicholascm90/tauri2-minimal/main/src-tauri/tauri.conf.json",
  "productName": "Bettercap UI",
  "version": "0.1.0",
  "identifier": "com.bettercap-ui.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bettercap UI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common",
          "libssl3"
        ],
        "section": "net",
        "priority": "optional"
      }
    }
  }
}
